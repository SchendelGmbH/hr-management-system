# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/hr_management?schema=public"

# NextAuth Configuration
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# SMTP Configuration (Email Notifications)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="noreply@hr-system.com"

# Upload Configuration
UPLOAD_DIR="./public/uploads"

# Application
NODE_ENV="development"

# WooCommerce Integration (Optional - nur wenn WooCommerce-Import verwendet wird)
WOOCOMMERCE_URL="https://your-shop.com"
WOOCOMMERCE_CONSUMER_KEY="ck_your_consumer_key_here"
WOOCOMMERCE_CONSUMER_SECRET="cs_your_consumer_secret_here"
