// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String?   @unique
  passwordHash  String
  role          String    @default("USER")
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  auditLogs            AuditLog[]
  notifications        Notification[]
  documentsUploaded       Document[]       @relation("DocumentUploader")
  clothingOrdersCreated   ClothingOrder[]  @relation("ClothingOrderCreator")
  vacationsCreated        Vacation[]       @relation("VacationCreator")
  qualificationsCreated   Qualification[]  @relation("QualificationCreator")
  dailyPlansCreated       DailyPlan[]      @relation("DailyPlanCreator")
  employee             Employee?
  
  // Shift Swap Relations
  approvedSwaps         ShiftSwap[]       @relation("SwapApprover")
  approvedSwapResponses SwapResponse[]    @relation("SwapResponseApprover")
  
  // Chat Relations
  chatMemberships       ChatMember[]
  chatMessages          ChatMessage[]
  chatReactions         ChatReaction[]

  @@map("users")
}

// ============================================================================
// DEPARTMENT
// ============================================================================

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  employees Employee[]

  @@map("departments")
}

// ============================================================================
// EMPLOYEE & CUSTOM FIELDS
// ============================================================================

model Employee {
  id                String    @id @default(cuid())
  employeeNumber    String    @unique // Auto-generated: EMP-00001
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  /// @encrypted
  email             String?
  /// @encrypted
  phone             String?
  departmentId      String?
  position          String?
  startDate         DateTime?
  clothingBudget    Decimal   @db.Decimal(10, 2) @default(0)
  remainingBudget   Decimal   @db.Decimal(10, 2) @default(0)
  lastBudgetReset   DateTime?

  // Adresse
  /// @encrypted
  street              String?
  /// @encrypted
  zipCode             String?
  /// @encrypted
  city                String?

  // Steuern & Sozialversicherung
  /// @encrypted
  socialSecurityNumber String?
  /// @encrypted
  taxId               String?
  /// @encrypted
  healthInsurance     String?

  // Vertrag & Vergütung
  isFixedTerm         Boolean   @default(false)
  fixedTermEndDate    DateTime?
  probationEndDate    DateTime?
  hourlyWage              Decimal?  @db.Decimal(10, 2)
  overtariffSupplement    Decimal?  @db.Decimal(10, 2)
  payGradeId              String?
  vacationDays            Int?

  // Zugang & Identifikation
  /// @encrypted
  keyNumber           String?
  /// @encrypted
  chipNumber          String?

  // Qualifikationen & Lizenzen
  driversLicenseClass String?   @default("Nein")
  forkliftLicense     Boolean   @default(false)

  // Portal-Zugang
  userId            String?   @unique

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  department         Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  payGrade           PayGrade?             @relation(fields: [payGradeId], references: [id], onDelete: SetNull)
  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  documents          Document[]
  customFieldValues  CustomFieldValue[]
  employeeSize       EmployeeSize?
  clothingOrders     ClothingOrder[]
  vacations          Vacation[]
  qualifications     Qualification[]
  planAssignments    DailyPlanAssignment[]
  
  // Shift Swap Relations
  swapRequests       ShiftSwap[]      @relation("SwapRequester")
  swapRequestedFor   ShiftSwap[]      @relation("SwapRequested")
  swapResponses      SwapResponse[]   @relation("SwapResponder")

  @@index([departmentId])
  @@index([payGradeId])
  @@index([email])
  @@index([employeeNumber])
  @@map("employees")
}

model CustomFieldDefinition {
  id             String   @id @default(cuid())
  fieldName      String   @unique
  fieldType      FieldType
  isRequired     Boolean  @default(false)
  sortOrder      Int      @default(0)
  selectOptions  Json?    // Array of strings for SELECT type
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  values CustomFieldValue[]

  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id              String   @id @default(cuid())
  employeeId      String
  fieldDefinitionId String
  textValue       String?
  numberValue     Decimal? @db.Decimal(15, 2)
  dateValue       DateTime?
  booleanValue    Boolean?
  selectValue     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  employee        Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fieldDefinition CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)

  @@unique([employeeId, fieldDefinitionId])
  @@index([employeeId])
  @@index([fieldDefinitionId])
  @@map("custom_field_values")
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

// ============================================================================
// DOCUMENTS
// ============================================================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?  @default("#3B82F6") // Hex color code
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  documents DocumentCategory[]

  @@map("categories")
}

model Document {
  id             String       @id @default(cuid())
  employeeId     String
  /// @encrypted
  title          String
  /// @encrypted
  description    String?      @db.Text
  filePath       String?      // Relative path: uploads/documents/2024/01/... (null für Container)
  printFilePath  String?      // Druckversion ohne Briefbogen (null wenn kein Briefbogen konfiguriert)
  fileName       String?      // null für Container
  fileSize       Int?         // In bytes (null für Container)
  mimeType       String?      // null für Container
  validFrom      DateTime?
  expirationDate DateTime?
  /// @encrypted
  notes          String?      @db.Text
  uploadedAt     DateTime     @default(now())
  uploadedBy     String
  updatedAt      DateTime     @updatedAt

  // Versionierung
  isContainer       Boolean   @default(false) // true = virtueller Container ohne Datei
  parentDocumentId  String?   // null = Container; gesetzt = zeigt auf Container der Gruppe
  versionNumber     Int       @default(1)     // 0 für Container, 1-n für Versionen

  // Dashboard Snooze
  snoozedUntil      DateTime? // null = sichtbar; gesetzt = bis zu diesem Datum im Dashboard ausgeblendet

  // Volltextsuche (nur auf Versions-Documents; max. 10.000 Zeichen; verschlüsselt)
  /// @encrypted
  textContent       String?   @db.Text

  // Relations
  employee   Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploader   User               @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)
  categories DocumentCategory[]

  // Selbst-Relation für Versionierung
  parent   Document?  @relation("DocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  versions Document[] @relation("DocumentVersions")

  @@index([employeeId])
  @@index([expirationDate])
  @@index([uploadedBy])
  @@index([parentDocumentId])
  @@map("documents")
}

model DocumentCategory {
  id         String   @id @default(cuid())
  documentId String
  categoryId String
  createdAt  DateTime @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([documentId, categoryId])
  @@index([documentId])
  @@index([categoryId])
  @@map("document_categories")
}

// ============================================================================
// CLOTHING / ARBEITSKLEIDUNG
// ============================================================================

model EmployeeSize {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  shirtSize      String?  // XS, S, M, L, XL, XXL, 3XL
  pantsSize      String?  // Konfektionsgröße oder Maße
  shoeSize       String?  // EU 35-50
  gloveSize      String?  // 6-12
  jacketSize     String?  // XS-3XL
  additionalSizes Json?   // Flexible JSON for additional sizes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_sizes")
}

model ClothingItem {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  category       String
  basePrice      Decimal  @db.Decimal(10, 2)
  availableSizes Json     // Array of available sizes
  imageUrl       String?
  isActive       Boolean  @default(true)

  // WooCommerce Integration Fields
  sku                  String?   @unique  // Stock Keeping Unit
  woocommerceId        Int?      @unique  // WooCommerce Product ID
  syncedToWooCommerce  Boolean   @default(false)
  lastSyncedAt         DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  orderItems ClothingOrderItem[]

  @@index([isActive])
  @@index([category])
  @@index([woocommerceId])
  @@index([sku])
  @@map("clothing_items")
}

model ClothingOrder {
  id          String            @id @default(cuid())
  employeeId  String
  orderDate   DateTime          @default(now())
  totalAmount Decimal           @db.Decimal(10, 2)
  status      OrderStatus       @default(ORDERED)
  notes       String?           @db.Text
  createdBy   String

  // WooCommerce Integration Fields
  woocommerceOrderId Int?      @unique  // WooCommerce Order ID
  importedFromWC     Boolean   @default(false)
  lastSyncedAt       DateTime?

  // Status Timestamps
  deliveredAt DateTime?  // Timestamp when status changed to DELIVERED
  returnedAt  DateTime?  // Timestamp when status changed to RETURNED

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  employee    Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  creator     User              @relation("ClothingOrderCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  items       ClothingOrderItem[]

  @@index([employeeId])
  @@index([status])
  @@index([orderDate])
  @@index([woocommerceOrderId])
  @@map("clothing_orders")
}

model ClothingOrderItem {
  id             String   @id @default(cuid())
  orderId        String
  clothingItemId String
  size           String
  quantity       Int      @default(1)
  unitPrice      Decimal  @db.Decimal(10, 2)
  totalPrice     Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  // Relations
  order        ClothingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  clothingItem ClothingItem  @relation(fields: [clothingItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([clothingItemId])
  @@map("clothing_order_items")
}

enum OrderStatus {
  ORDERED
  DELIVERED
  RETURNED
}

// ============================================================================
// VACATION / URLAUB
// ============================================================================

model Vacation {
  id           String       @id @default(cuid())
  employeeId   String
  startDate    DateTime
  endDate      DateTime
  vacationType VacationType @default(VACATION)
  notes        String?      @db.Text
  createdBy    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  creator  User     @relation("VacationCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([startDate])
  @@index([endDate])
  @@map("vacations")
}

enum VacationType {
  VACATION
  SICK
  SPECIAL
  SCHOOL        // Reguläre Berufsschule (Azubi-Tage)
  SCHOOL_BLOCK  // UBL – Berufsschule-Blockwoche (mehrere Tage)
}

// ============================================================================
// QUALIFICATIONS, CERTIFICATES & TRAINING
// ============================================================================

enum QualificationGroup {
  INSTRUCTION  // Unterweisungen
  CERTIFICATE  // Zertifikate & Lizenzen
  TRAINING     // Fortbildungen
}

model QualificationType {
  id                      String             @id @default(cuid())
  name                    String
  group                   QualificationGroup
  recurringIntervalMonths Int?               // null = einmalig; 12 = jährlich
  isActive                Boolean            @default(true)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  qualifications Qualification[]

  @@unique([name, group])
  @@map("qualification_types")
}

model Qualification {
  id         String    @id @default(cuid())
  employeeId String
  typeId     String
  issuedAt   DateTime?
  expiresAt  DateTime?
  issuer     String?
  certNumber String?
  filePath   String?
  fileName   String?
  notes      String?   @db.Text
  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type     QualificationType @relation(fields: [typeId], references: [id])
  creator  User              @relation("QualificationCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([expiresAt])
  @@index([typeId])
  @@map("qualifications")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id                String           @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  message           String           @db.Text
  isRead            Boolean          @default(false)
  relatedEntityType String?          // e.g., "Document", "Employee"
  relatedEntityId   String?
  createdAt         DateTime         @default(now())
  readAt            DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  DOCUMENT_EXPIRING
  DOCUMENT_EXPIRED
  LOW_BUDGET
  UPCOMING_VACATION
  QUALIFICATION_EXPIRING
}

// ============================================================================
// AUDIT LOG
// ============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entityType String   // Employee, Document, etc.
  entityId   String?
  oldValues  Json?    // Previous state (for UPDATE)
  newValues  Json?    // New state (for CREATE, UPDATE)
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// DOKUMENTVORLAGEN / DOCUMENT TEMPLATES
// ============================================================================

model DocumentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   @db.Text  // HTML-Inhalt aus TipTap-Editor
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("document_templates")
}

// ============================================================================
// SYSTEM SETTINGS
// ============================================================================

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ============================================================================
// PAY GRADES (LOHNGRUPPEN)
// ============================================================================

model PayGrade {
  id          String    @id @default(cuid())
  name        String
  description String?
  tariffWage  Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees   Employee[]

  @@map("pay_grades")
}

// ============================================================================
// TAGESPLANUNG (EINSATZPLANUNG)
// ============================================================================

model WorkSite {
  id                  String   @id @default(cuid())
  name                String
  location            String?
  color               String?
  defaultStartTime    String   @default("06:00")
  defaultEndTime      String   @default("16:00")
  defaultVehiclePlate String?
  lastUsedAt          DateTime @default(now())
  createdAt           DateTime @default(now())

  planSites DailyPlanSite[]

  @@unique([name, location])
  @@index([lastUsedAt])
  @@map("work_sites")
}

model DailyPlan {
  id        String   @id @default(cuid())
  date      DateTime @unique
  notes     String?  @db.Text
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User          @relation("DailyPlanCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  sites   DailyPlanSite[]

  @@index([date])
  @@map("daily_plans")
}

model DailyPlanSite {
  id           String  @id @default(cuid())
  planId       String
  workSiteId   String?
  name         String
  location     String?
  color        String?
  vehiclePlates String[]
  startTime    String  @default("06:00")
  endTime      String  @default("16:00")
  sortOrder    Int     @default(0)

  plan        DailyPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  workSite    WorkSite?            @relation(fields: [workSiteId], references: [id], onDelete: SetNull)
  assignments DailyPlanAssignment[]

  @@index([planId])
  @@map("daily_plan_sites")
}

model DailyPlanAssignment {
  id         String  @id @default(cuid())
  siteId     String
  employeeId String
  note       String?

  // Shift Swap Relations
  swapRequestsAsRequester ShiftSwap[]     @relation("RequesterShift")
  swapRequestsAsResponder SwapResponse[]  @relation("ResponderShift")

  site     DailyPlanSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([siteId, employeeId])
  @@index([employeeId])
  @@map("daily_plan_assignments")
}

// ============================================================================
// FAHRZEUGE (VEHICLES)
// ============================================================================

model Vehicle {
  id          String   @id @default(cuid())
  plate       String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("vehicles")
}

// ============================================================================
// SHIFT SWAP SYSTEM (SCHICHT-TAUSCH)
// ============================================================================

enum SwapRequestStatus {
  PENDING     // Ausstehend
  APPROVED    // Genehmigt
  REJECTED    // Abgelehnt
  CANCELLED   // Storniert
  COMPLETED   // Abgeschlossen (Schichten wurden getauscht)
}

model ShiftSwap {
  id              String   @id @default(cuid())
  
  // Mitarbeiter, der tauschen möchte
  requesterId     String
  requesterShiftId String  // Verknüpfung zu DailyPlanAssignment
  
  // Schicht-Details des Anfragenden
  requesterDate   DateTime
  requesterSiteId String
  requesterStartTime String
  requesterEndTime   String
  
  // Optional: Gewünschter Tauschpartner
  requestedEmployeeId String?
  requestedShiftId    String?
  
  // Status und Zeiten
  status          SwapRequestStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  expiresAt       DateTime?    // Wann läuft die Anfrage ab
  
  // Beschreibung/Notizen
  note            String?      @db.Text
  
  // Genehmigung
  approvedBy      String?
  approvedAt      DateTime?
  approvalNote    String?      @db.Text
  
  // Relations
  requester       Employee     @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requested       Employee?    @relation("SwapRequested", fields: [requestedEmployeeId], references: [id], onDelete: SetNull)
  requesterShift    DailyPlanAssignment @relation("RequesterShift", fields: [requesterShiftId], references: [id], onDelete: Cascade)
  approvedByUser  User?        @relation("SwapApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  
  // Antworten auf diese Anfrage
  responses       SwapResponse[]
  
  @@index([requesterId])
  @@index([requestedEmployeeId])
  @@index([status])
  @@index([requesterDate])
  @@index([createdAt])
  @@map("shift_swaps")
}

model SwapResponse {
  id              String   @id @default(cuid())
  swapRequestId   String
  responderId     String   // Mitarbeiter, der antwortet
  
  // Schicht des Responders (die er anbietet)
  responderShiftId String
  responderDate   DateTime
  responderSiteId String
  
  // Status der Antwort
  status          SwapRequestStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  // Genehmigungs-Details
  approvedBy      String?
  approvedAt      DateTime?
  
  // Relations
  swapRequest     ShiftSwap    @relation(fields: [swapRequestId], references: [id], onDelete: Cascade)
  responder       Employee     @relation("SwapResponder", fields: [responderId], references: [id], onDelete: Cascade)
  responderShift    DailyPlanAssignment @relation("ResponderShift", fields: [responderShiftId], references: [id], onDelete: Cascade)
  approvedByUser  User?        @relation("SwapResponseApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  
  @@unique([swapRequestId, responderId])
  @@index([swapRequestId])
  @@index([responderId])
  @@index([status])
  @@map("swap_responses")
}

// Erweiterung DailyPlanAssignment für Swap-Relations
// (Hinweis: Die Relations werden oben definiert, 
//  DailyPlanAssignment selbst bleibt unverändert)

// ============================================================================
// CHAT SYSTEM
// ============================================================================

enum ChatRoomType {
  DIRECT      // Direktchat zwischen 2 Personen
  GROUP       // Gruppenchat
  DEPARTMENT  // Abteilungschat (automatisch)
  SYSTEM      // System-/Willkommensnachrichten
}

enum ChatMemberRole {
  MEMBER
  ADMIN
  OWNER
}

model ChatRoom {
  id          String       @id @default(cuid())
  name        String?
  type        ChatRoomType
  isSystem    Boolean      @default(false)
  description String?
  avatarUrl   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Relations
  members     ChatMember[]
  messages    ChatMessage[]
  
  // Für Gruppen: Wer hat sie erstellt
  createdBy   String?
  
  // Für System-Räume: Verknüpfung zu Entities
  relatedEntityType String?  // z.B. "Employee" für Willkommenschat
  relatedEntityId   String?
  
  @@index([type])
  @@index([isSystem])
  @@index([relatedEntityType, relatedEntityId])
  @@map("chat_rooms")
}

model ChatMember {
  id         String         @id @default(cuid())
  roomId     String
  userId     String
  role       ChatMemberRole @default(MEMBER)
  joinedAt   DateTime       @default(now())
  lastReadAt DateTime?      // Zeitpunkt der letzten Lesebestätigung
  isMuted    Boolean        @default(false)
  
  // Relations
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([joinedAt])
  @@map("chat_members")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String?  // null für Systemnachrichten
  content   String   @db.Text
  
  // Metadata
  sentAt    DateTime @default(now())
  editedAt  DateTime?
  isSystem  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  
  // Reply functionality
  replyToId String?
  
  // Relations
  room     ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender   User?            @relation(fields: [senderId], references: [id], onDelete: SetNull)
  replyTo  ChatMessage?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies  ChatMessage[]    @relation("MessageReplies")
  reactions ChatReaction[]
  attachments ChatAttachment[]
  
  @@index([roomId])
  @@index([roomId, sentAt])
  @@index([senderId])
  @@index([replyToId])
  @@map("chat_messages")
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String   // Unicode emoji oder shortcode
  reactedAt DateTime @default(now())
  
  // Relations
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@map("chat_reactions")
}

model ChatAttachment {
  id          String   @id @default(cuid())
  messageId   String
  filePath    String   // Upload path
  fileName    String
  fileSize    Int
  mimeType    String
  
  // Für Bilder
  width       Int?
  height      Int?
  thumbnailPath String?
  
  uploadedAt  DateTime @default(now())
  
  // Relations
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  @@index([messageId])
  @@map("chat_attachments")
}
