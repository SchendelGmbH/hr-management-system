# ============================================================
# Docker-Umgebungsvariablen – Vorlage
# Kopiere diese Datei nach ".env" und fülle die Werte aus.
# ============================================================

# ── Datenbank ─────────────────────────────────────────────
# Starkes Passwort für den PostgreSQL-Benutzer wählen
POSTGRES_PASSWORD=HIER_STARKES_PASSWORT_EINTRAGEN

# ── NextAuth ──────────────────────────────────────────────
# Zufälligen 32+ Zeichen langen Secret generieren:
#   PowerShell: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#   oder:       openssl rand -base64 32
NEXTAUTH_SECRET=HIER_ZUFAELLIGEN_SECRET_EINTRAGEN

# URL des Servers – IP-Adresse oder Hostname des Windows-Servers
# Beispiel: http://192.168.1.100:3000  oder  http://hr-server:3000
NEXTAUTH_URL=http://IP-DES-SERVERS:3000

# ── Verschlüsselungsschlüssel (Prisma Field Encryption) ──
# Format: k1.aesgcm256.<base64-schlüssel>
# Neu generieren: npx prisma-field-encryption generate-key
PRISMA_FIELD_ENCRYPTION_KEY=HIER_VERSCHLUESSELUNGSSCHLUESSEL_EINTRAGEN

# ── WooCommerce (optional – weglassen wenn nicht benötigt) ─
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
