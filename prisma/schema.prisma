// ============================================================================
// TASK MANAGEMENT SYSTEM
// ============================================================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  
  // Assignee
  assigneeId  String?
  assignee    Employee?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  
  // Creator
  createdById String
  createdBy   User       @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  
  // Due Date
  dueDate     DateTime?
  completedAt DateTime?
  
  // Source (for chat-created tasks)
  sourceRoomId   String?    // Chat room ID where task was created
  sourceMessageId String?   // Original message ID
  
  // Timestamps
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Audit
  auditLogs   TaskAuditLog[]
  
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([createdById])
  @@index([createdAt])
  @@map("tasks")
}

model TaskAuditLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  action    String   // CREATED, UPDATED, STATUS_CHANGED, ASSIGNED, COMPLETED
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  
  performedById String
  performedBy   User   @relation(fields: [performedById], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([taskId])
  @@index([performedById])
  @@map("task_audit_logs")
}

// Extend User model with task relations
// Add to User model: createdTasks Task[], taskAuditLogs TaskAuditLog[]
// ============================================================================

enum ChatRoomType {
  DIRECT      // Direktchat zwischen 2 Personen
  GROUP       // Gruppenchat
  DEPARTMENT  // Abteilungschat (automatisch)
  SYSTEM      // System-/Willkommensnachrichten
  WORKSITE    // Baustellen-Chat (automatisch bei Baustellen-Anlage)
}

enum ChatMemberRole {
  MEMBER
  ADMIN
  OWNER
}

model ChatRoom {
  id          String       @id @default(cuid())
  name        String?
  type        ChatRoomType
  isSystem    Boolean      @default(false)
  description String?
  avatarUrl   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Relations
  members     ChatMember[]
  messages    ChatMessage[]
  
  // Für Gruppen: Wer hat sie erstellt
  createdBy   String?
  
  // Für System-Räume: Verknüpfung zu Entities
  relatedEntityType String?  // z.B. "Employee" für Willkommenschat
  relatedEntityId   String?
  
  // Document Signature Workflow
  signatureRequests DocumentSignatureRequest[]
  
  @@index([type])
  @@index([isSystem])
  @@index([relatedEntityType, relatedEntityId])
  @@map("chat_rooms")
}

model ChatMember {
  id         String         @id @default(cuid())
  roomId     String
  userId     String
  role       ChatMemberRole @default(MEMBER)
  joinedAt   DateTime       @default(now())
  lastReadAt DateTime?      // Zeitpunkt der letzten Lesebestätigung
  isMuted    Boolean        @default(false)
  
  // Relations
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([joinedAt])
  @@map("chat_members")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String?  // null für Systemnachrichten
  content   String   @db.Text
  
  // Metadata
  sentAt    DateTime @default(now())
  editedAt  DateTime?
  isSystem  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  
  // Reply functionality
  replyToId String?
  
  // Relations
  room     ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender   User?            @relation(fields: [senderId], references: [id], onDelete: SetNull)
  replyTo  ChatMessage?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies  ChatMessage[]    @relation("MessageReplies")
  reactions ChatReaction[]
  attachments ChatAttachment[]
  
  @@index([roomId])
  @@index([roomId, sentAt])
  @@index([senderId])
  @@index([replyToId])
  @@map("chat_messages")
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String   // Unicode emoji oder shortcode
  reactedAt DateTime @default(now())
  
  // Relations
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@map("chat_reactions")
}

model ChatAttachment {
  id          String   @id @default(cuid())
  messageId   String
  filePath    String   // Upload path
  fileName    String
  fileSize    Int
  mimeType    String
  
  // Für Bilder
  width       Int?
  height      Int?
  thumbnailPath String?
  
  uploadedAt  DateTime @default(now())
  
  // Relations
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  @@index([messageId])
  @@map("chat_attachments")
}

// ============================================================================
// BAUSTELLEN CHECK-IN/CHECK-OUT (für Chat-Feature)
// ============================================================================

model WorkSiteCheckIn {
  id            String    @id @default(cuid())
  userId        String
  workSiteId    String?   // Optional: für globale Check-ins ohne Baustelle
  date          DateTime  @default(now()) @db.Date
  checkedInAt   DateTime  @default(now())
  checkedOutAt  DateTime?
  
  // Optional: Koordinaten für GPS-Check-in
  latitude      Float?
  longitude     Float?
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workSite      WorkSite? @relation(fields: [workSiteId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([workSiteId])
  @@index([date])
  @@index([checkedOutAt]) // Für Abfragen: wer ist noch eingecheckt
  @@map("work_site_check_ins")
}

// ============================================================================
// DOCUMENT SIGNATURE WORKFLOW
// ============================================================================

enum SignatureRequestStatus {
  PENDING
  APPROVED
  SIGNED
  REJECTED
  CANCELLED
}

enum SignatureRequestRole {
  REQUESTER
  APPROVER
  SIGNER
}

model DocumentSignatureRequest {
  id              String                   @id @default(cuid())
  documentId      String                   // Container-Dokument
  document        Document                 @relation("DocumentSignatureRequests", fields: [documentId], references: [id], onDelete: Cascade)
  
  // Workflow
  status          SignatureRequestStatus   @default(PENDING)
  title           String                   // Titel der Signatur-Anfrage
  message         String?                  // Nachricht an Empfänger
  
  // Creator
  createdById     String
  createdBy       User                     @relation("SignatureRequestCreator", fields: [createdById], references: [id], onDelete: Cascade)
  
  // Chat integration
  roomId          String?                  // Chat-Raum für diese Anfrage
  room            ChatRoom?                @relation(fields: [roomId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  approvedAt      DateTime?
  signedAt      DateTime?
  rejectedAt    DateTime?
  
  // Relations
  participants    DocumentSignatureParticipant[]
  signatures      DocumentSignature[]
  
  @@index([documentId])
  @@index([status])
  @@index([createdById])
  @@index([roomId])
  @@map("document_signature_requests")
}

model DocumentSignatureParticipant {
  id          String              @id @default(cuid())
  requestId   String
  request     DocumentSignatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role        SignatureRequestRole
  actedAt     DateTime?           // Wann die Aktion ausgeführt wurde
  note        String?             // Notiz bei Ablehnung
  
  @@unique([requestId, userId, role])
  @@index([requestId])
  @@index([userId])
  @@map("document_signature_participants")
}

model DocumentSignature {
  id          String                   @id @default(cuid())
  requestId   String
  request     DocumentSignatureRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  // Wer unterschreibt
  signerId    String
  signer      User                     @relation("DocumentSigner", fields: [signerId], references: [id], onDelete: Cascade)
  
  // Signatur-Daten
  signatureData   String               @db.Text // Base64-encoded SVG/PNG der Signatur
  signedAt        DateTime             @default(now())
  ipAddress       String?
  userAgent       String?
  
  // PDF-Seitennummer
  pageNumber      Int                  @default(1)
  positionX       Float?               // X-Koordinate in PDF (0-1)
  positionY       Float?               // Y-Koordinate in PDF (0-1)
  
  @@index([requestId])
  @@index([signerId])
  @@map("document_signatures")
}

